rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isCoach() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/coaches/$(request.auth.uid));
    }

    // Audio recordings — coaches only; parent portal must not read raw recordings
    match /audio/{allPaths=**} {
      allow read: if isCoach();
      allow write: if isCoach()
        && request.resource.size < 100 * 1024 * 1024  // 100MB max
        && request.resource.contentType.matches('audio/.*');
    }

    // Video recordings — coaches only; parent portal must not read raw videos
    match /video/{allPaths=**} {
      allow read: if isCoach();
      allow write: if isCoach()
        && request.resource.size < 500 * 1024 * 1024  // 500MB max
        && request.resource.contentType.matches('video/.*');
    }

    // Profile photos
    match /profiles/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024  // 5MB max
        && request.resource.contentType.matches('image/.*');
    }

    // Import files — coaches only
    match /imports/{allPaths=**} {
      allow read: if isCoach();
      allow write: if isCoach()
        && request.resource.size < 50 * 1024 * 1024;
    }
  }
}
