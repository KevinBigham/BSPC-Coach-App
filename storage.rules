rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Audio recordings — authenticated coaches can upload and read
    match /audio/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 100 * 1024 * 1024  // 100MB max
        && request.resource.contentType.matches('audio/.*');
    }

    // Video recordings — authenticated coaches can upload and read
    match /video/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 500 * 1024 * 1024  // 500MB max
        && request.resource.contentType.matches('video/.*');
    }

    // Profile photos
    match /profiles/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024  // 5MB max
        && request.resource.contentType.matches('image/.*');
    }

    // Spike test data — open during development
    match /spike_audio/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
