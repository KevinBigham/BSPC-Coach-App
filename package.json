{
  "name": "bspc-coach",
  "version": "1.3.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "prepare": "husky",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:errors": "eslint . --ext .ts,.tsx --quiet",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'app/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "build:dev": "eas build --profile development --platform all",
    "build:preview": "eas build --profile preview --platform all",
    "build:prod": "eas build --profile production --platform all",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "quality": "npm run typecheck && npm run lint:errors && npm test -- --runInBand && npm --prefix functions test -- --runInBand && npm --prefix functions run build && npm --prefix parent-portal run typecheck && npm --prefix parent-portal run lint && npm --prefix parent-portal run build && npm run madge:circular && npm run quality:strict-types && npm run quality:randomness",
    "quality:dead-code": "knip",
    "quality:strict-types": "bash scripts/check-strict-types.sh",
    "quality:randomness": "bash scripts/check-randomness.sh",
    "knip": "knip",
    "madge:circular": "madge --circular --extensions ts,tsx src app functions/src",
    "ts-prune": "ts-prune",
    "depcheck": "depcheck"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@config-plugins/react-native-blob-util": "^12.0.0",
    "@config-plugins/react-native-pdf": "^12.0.0",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/press-start-2p": "^0.4.1",
    "@expo-google-fonts/teko": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/netinfo": "11.4.1",
    "@sentry/react-native": "^8.7.0",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "^55.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "firebase": "^12.11.0",
    "lucide-react-native": "^1.7.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-blob-util": "^0.24.7",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pdf": "^7.0.4",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "babel-preset-expo": "^55.0.15",
    "depcheck": "^1.4.7",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "firebase-admin": "^13.8.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.13",
    "knip": "^6.4.1",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "react-native-worklets": "^0.8.1",
    "react-test-renderer": "^19.1.0",
    "ts-prune": "^0.10.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
