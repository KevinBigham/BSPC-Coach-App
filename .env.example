# BSPC Coach App local environment template.
# Copy to .env and fill with your own Firebase project values.
# Never commit .env, service-account JSON, native signing credentials, or real team data.

# Expo coach app Firebase web config.
# These EXPO_PUBLIC_* values are public client configuration, not secrets.
EXPO_PUBLIC_FIREBASE_API_KEY=replace_with_firebase_web_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=replace-with-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=replace-with-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=replace-with-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Optional Sentry DSN for the Expo coach app. Public DSN only.
EXPO_PUBLIC_SENTRY_DSN=

# Parent portal Firebase web config.
# Usually mirrors the Expo Firebase project, but keep it explicit for Next.js.
NEXT_PUBLIC_FIREBASE_API_KEY=replace_with_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace-with-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace-with-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace-with-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Cloud Functions local/emulator settings.
# Firebase sets GCLOUD_PROJECT in deployed Functions. Set locally only when needed.
GCLOUD_PROJECT=replace-with-project-id
CALENDAR_ICS_URL=

# Deployment secrets are configured in GitHub/EAS/Firebase, not in .env:
# EXPO_TOKEN
# FIREBASE_TOKEN
# GOOGLE_APPLICATION_CREDENTIALS
